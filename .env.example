PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
PLAID_STORAGE_PATH=data/plaid.sqlite3

# Application environment: local, staging, or production
APP_ENV=local
LOG_LEVEL=INFO
DEFAULT_CLIENT_USER_ID=spendant-local-user

# Optional comma-separated browser origins for CORS
# CORS_ORIGINS=http://localhost:3000,https://staging.spendant.app

# Public API URL used for Plaid webhooks (required in production)
# API_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Optional managed Postgres URL. When unset, SQLite at PLAID_STORAGE_PATH is used.
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/spendant

# Encrypt Plaid access tokens at rest
TOKEN_ENCRYPTION_KEY=local-dev-token-encryption-key
TOKEN_KEY_VERSION=v1

# Managed auth (required when APP_ENV != local or AUTH_REQUIRED=true)
# AUTH_REQUIRED=true
# AUTH_ISSUER=https://your-auth-provider/
# AUTH_AUDIENCE=spendant-api
# AUTH_JWKS_URL=https://your-auth-provider/.well-known/jwks.json
# AUTH_USER_ID_CLAIM=sub

# Optional Plaid webhook verification key
# PLAID_WEBHOOK_VERIFICATION_KEY=
